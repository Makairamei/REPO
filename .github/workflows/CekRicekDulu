name: Cek Perubahan Domain

concurrency:
  group: ${{ github.workflow }}-${{ github.event_name }}-${{ github.ref }}
  cancel-in-progress: true

on:
  workflow_dispatch:

  schedule:
    # Jalankan setiap 6 jam sekali
    - cron: 25 */6 * * *

jobs:
  DomainCheck:
    runs-on: ubuntu-latest

    env:
      REPO_OWNER: ${{ github.repository_owner }}
      REPO_NAME: ${{ github.event.repository.name }}

    permissions:
      contents: write
      pull-requests: write

    steps:

      # Clone repository
      - name: Clone Repository
        uses: actions/checkout@v4
        with:
          # GANTI dengan secret token GitHub kamu
          token: ${{ secrets.PAT_TOKEN }}

      # Install Python
      - name: Install Python 3.11.8
        uses: actions/setup-python@v5
        with:
          python-version: 3.11.8

      # Tampilkan versi Python
      - name: Cek Versi Python
        run: python -c "import sys; print(sys.version)"

      # Install dependency Python
      - name: Install Dependency
        run: |
          python -m pip install --upgrade pip
          
          # TAMBAHKAN dependency lain jika diperlukan
          pip install -U setuptools wheel cloudscraper pycryptodome requests bs4

      # Jalankan script pengecekan domain
      - name: Jalankan Domain Checker
        run: |
          # GANTI nama file jika berbeda
          python DomainCheck.py

      # Cek apakah ada perubahan file
      - name: Cek Perubahan
        id: cek_perubahan
        run: |
          git diff --quiet . || echo "changed=true" >> $GITHUB_OUTPUT || true

      # Commit dan push otomatis jika ada perubahan
      - name: Push Perubahan
        if: steps.cek_perubahan.outputs.changed == 'true'
        run: |

          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"

          git add -A

          # GANTI pesan commit sesuai keinginan
          git commit -m "🤖 Update Domain Otomatis" \
            -m "🤖 Domain provider berhasil diperbarui otomatis."

          # GANTI branch jika bukan master
          git push origin master